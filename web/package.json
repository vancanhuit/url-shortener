    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^4.0.1",
    "redoc": "^2.5.2",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "swagger-ui-dist": "^5.32.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.0.13"
