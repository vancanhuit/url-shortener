{
  "name": "url-shortener-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vite + Svelte + Tailwind v4 SPA for the url-shortener web UI.",
  "scripts": {
    "generate": "openapi-generator-cli generate",
    "dev": "vite",
    "vendor:docs": "bun run scripts/vendor-docs-assets.ts",
    "prebuild": "bun run vendor:docs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint:js": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@tsconfig/svelte": "^5.0.8",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^4.0.1",
    "redoc": "^2.5.2",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "swagger-ui-dist": "^5.32.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
