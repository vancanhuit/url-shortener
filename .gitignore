# Binaries
/bin/
/dist/
*.exe
*.test
*.out

# Coverage
coverage.out
coverage.html

# Editor / OS
.idea/
.vscode/*
# Track shared editor settings so gopls/lint behave consistently for everyone.
!.vscode/settings.json
!.vscode/extensions.json
.DS_Store
*.swp

# Env files
.env
.env.local
.envrc

# Node (commitlint / tailwind toolchain)
node_modules/

# Tailwind / htmx outputs are build artifacts. The Go binary embeds them
# via `//go:embed`, so `just build` re-runs `just web-build` whenever they
# are missing. CI and the multi-stage Dockerfile do the same.
/web/static/styles.css
/web/static/htmx.min.js
/web/static/copy.js
