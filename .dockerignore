.git
.github
.husky
.idea
.vscode

# Build artifacts
bin/
dist/
coverage.out
coverage.html

# Local Node tooling (not needed inside the Go image build)
node_modules/

# Vite SPA output is rebuilt inside the web-builder stage; never
# ship a stale local build into the image build context.
web/dist/
# Vendored OpenAPI docs assets land in public/static at build time
# (see web/scripts/vendor-docs-assets.mjs); excluded for the same
# reason as web/dist/.
web/public/static/

# Local env files
.env
.env.local
.envrc

# Docs / planning artifacts unrelated to the build
*.md
!README.md
