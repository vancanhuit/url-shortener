#!/usr/bin/env bash
# [MISE] description="Scan an arbitrary image reference with Trivy (HIGH/CRITICAL, --ignore-unfixed)."
#USAGE arg "<image>" help="Image reference to scan (registry tag, digest, or local daemon image)"
set -euo pipefail
trivy image \
    --severity HIGH,CRITICAL \
    --ignore-unfixed \
    --exit-code 1 \
    --no-progress \
    "${usage_image}"
